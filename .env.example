# Public site URL (no trailing slash). Used for canonical, OG, sitemap.
SITE_URL=https://blog.codewithnaman.com

# Sub-path the site is served from. Leave blank for local dev and custom domains.
# Set to "/<repo>" only when deploying to GitHub Pages WITHOUT a custom domain.
BASE_PATH=

# --- Author / social handles ---
PUBLIC_GITHUB_HANDLE=
PUBLIC_TWITTER_HANDLE=
PUBLIC_CONTACT_EMAIL=

# --- Giscus ---
# Master switch. Set "true" to enable.
PUBLIC_GISCUS_ENABLED=false
PUBLIC_GISCUS_REPO=your-handle/your-repo
PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxxx
PUBLIC_GISCUS_CATEGORY=Announcements
PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxxx
