{
  "name": "codewithnaman-blog",
  "version": "0.1.0",
  "type": "module",
  "description": "CodeWithNaman Blog — Engineering, System Design, FinTech, Cloud & AI",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && npm run pagefind",
    "preview": "astro preview",
    "astro": "astro",
    "pagefind": "pagefind --site dist --output-subdir _pagefind",
    "postbuild": "echo \"Pagefind index generated in dist/_pagefind\"",
    "typecheck": "astro check",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,jsx,md,mdx,css,json}\"",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,jsx,md,mdx,css,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.3",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.22.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/lato": "5.2.7",
    "@fontsource/source-sans-3": "5.2.9",
    "@iconify-json/lucide": "^1.2.106",
    "@iconify-json/simple-icons": "^1.2.81",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.12",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "daisyui": "^5.5.19",
    "eslint": "^9.22.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "katex": "^0.16.45",
    "lint-staged": "^15.5.2",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "satori": "^0.26.0",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "zod": "^4.4.3"
  },
  "keywords": [
    "astro",
    "blog",
    "tailwindcss",
    "daisyui",
    "mdx",
    "pagefind"
  ]
}
