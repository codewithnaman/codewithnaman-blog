---
import type { Post } from '../utils/posts';
import PostCard from './PostCard.astro';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

{
  posts.length === 0 ? (
    <p class="border-base-300 text-base-content/70 rounded-md border border-dashed px-6 py-10 text-center">
      No posts yet.
    </p>
  ) : (
    <div id="post-list">
      {posts.map((post, index) => (
        <PostCard post={post} prioritizeLcp={index === 0} />
      ))}
    </div>
  )
}
