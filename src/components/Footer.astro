---
import { SITE } from '../config';
import { useTranslations } from '../i18n/utils';

const t = useTranslations();
const year = new Date().getFullYear();
const footerLeftText = SITE.footer.leftText?.trim();
const footerRightText = SITE.footer.rightText?.trim();
const showThemeCredits = SITE.footer.showThemeCredits ?? true;
const shouldRenderRightFooter = Boolean(footerRightText) || showThemeCredits;
const resolvedLeftText = footerLeftText
  ?.replaceAll('{year}', String(year))
  .replaceAll('{author}', SITE.author.name);
---

<footer
  aria-label="Site Info"
  class="border-base-300 text-base-content/70 mt-10 flex flex-col gap-1 border-t py-6 text-sm lg:flex-row lg:items-center lg:justify-between"
>
  <p>
    {
      resolvedLeftText ? (
        resolvedLeftText
      ) : (
        <>
          © <time>{year}</time>{' '}
          <a href={SITE.author.url ?? '#'} rel="noopener" class="hover:text-primary">
            {SITE.author.name}
          </a>
          . {t('footer.copyright')}
        </>
      )
    }
  </p>
  {
    shouldRenderRightFooter && (
      <p>
        {footerRightText ? (
          <>
            {footerRightText}
            {showThemeCredits && (
              <>
                {' · '}
                {t('footer.theme')}{' '}
                <a href={SITE.footer.themeUrl} rel="noopener" class="hover:text-primary">
                  {SITE.footer.themeName}
                </a>
              </>
            )}
          </>
        ) : (
          <>
            {t('footer.poweredBy')}{' '}
            <a href="https://astro.build" rel="noopener" class="hover:text-primary">
              Astro
            </a>{' '}
            · {t('footer.theme')}{' '}
            <a href={SITE.footer.themeUrl} rel="noopener" class="hover:text-primary">
              {SITE.footer.themeName}
            </a>
          </>
        )}
      </p>
    )
  }
</footer>
