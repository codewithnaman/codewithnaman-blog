---
/**
 * Chirpy-style fixed left sidebar: logo + tagline,
 * uppercase vertical nav with icon bullets, theme toggle + social
 * pinned to the bottom. Collapsible to icon-only mode.
 */

import { SITE, NAV, SOCIALS } from '../config';
import { useTranslations, withBase } from '../i18n/utils';
import type { UIKey } from '../i18n/ui';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import ThemeToggle from './islands/ThemeToggle.astro';
import cwnLogo from '../assets/images/site/CWN Logo.png';

const t = useTranslations();
const home = '/';

const navItems = NAV.map((item) => ({
  ...item,
  href: item.href,
  label: t(`nav.${item.key}` as UIKey),
}));
---

<aside id="sidebar" class="chirpy-sidebar" aria-label="Sidebar">
  {/* Profile */}
  <header class="sidebar-expanded-only flex w-full flex-col items-center pt-4 pb-6 text-center">
    <div class="flex w-full items-center justify-center gap-2">
      <a href={home} class="flex flex-col items-center" aria-label={SITE.title}>
        <Image
          src={cwnLogo}
          alt={SITE.title}
          width={180}
          class="w-auto object-contain"
          loading="eager"
          decoding="async"
        />
      </a>
      {/* Collapse button — next to logo when expanded */}
      <button
        type="button"
        id="sidebar-collapse-btn"
        class="sidebar-expanded-collapse-btn flex h-9 w-9 shrink-0 items-center justify-center rounded-md transition"
        aria-label="Collapse sidebar"
      >
        <Icon name="lucide:panel-left-close" width={16} height={16} />
      </button>
    </div>
    {
      SITE.author.bio && (
        <p class="text-base-content/70 mt-1 max-w-56 text-sm italic">{SITE.author.bio}</p>
      )
    }
  </header>

  {/* Collapse toggle — shown as first nav item when collapsed */}
  <button
    type="button"
    id="sidebar-expand-btn"
    class="chirpy-nav-link sidebar-expand-btn"
    aria-label="Expand sidebar"
  >
    <Icon name="lucide:panel-left-open" width={16} height={16} />
  </button>

  {/* Vertical nav */}
  <nav class="chirpy-nav flex-1" aria-label="Main">
    <ul class="contents flex-col gap-0.5">
      {
        navItems.map((item) => {
          const stripped = item.href.replace(/\/+$/, '') || '/';
          const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
          const isActive =
            stripped === current ||
            (stripped !== home.replace(/\/+$/, '') && current.startsWith(stripped + '/'));
          return (
            <li>
              <a
                href={item.href}
                aria-current={isActive ? 'page' : undefined}
                class="chirpy-nav-link"
                {...(item.href.startsWith('http') ? { target: '_blank', rel: 'noopener' } : {})}
              >
                <Icon name={item.icon ?? 'lucide:home'} width={16} height={16} />
                <span>{item.label}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>

  {/* Bottom row: theme toggle + RSS (always visible) + socials (hidden when collapsed) */}
  <div
    class="border-base-300 mt-4 flex w-full flex-wrap items-center justify-center gap-2 border-t pt-4"
  >
    <ThemeToggle />
    {
      SOCIALS.map((s) => (
        <a
          href={s.href.startsWith('/') ? withBase(s.href) : s.href}
          rel="noopener"
          class="chirpy-social"
          class:list={['chirpy-social', s.label === 'RSS' ? '' : 'sidebar-expanded-only']}
          aria-label={s.label}
          target={s.href.startsWith('http') || s.label === 'RSS' ? '_blank' : undefined}
        >
          <Icon name={s.icon} width={16} height={16} />
        </a>
      ))
    }
  </div>
</aside>

{/* Mobile backdrop */}
<button
  type="button"
  data-sidebar-mask
  class="fixed inset-0 z-30 hidden bg-black/40 lg:hidden"
  aria-label="Close sidebar"
  tabindex="-1"></button>

<script>
  const STORAGE_KEY = 'sidebar-collapsed';

  function setupSidebar() {
    const sidebar = document.getElementById('sidebar');
    const mask = document.querySelector<HTMLElement>('[data-sidebar-mask]');
    const collapseBtn = document.getElementById('sidebar-collapse-btn');
    const expandBtn = document.getElementById('sidebar-expand-btn');
    if (!sidebar || !mask) return;

    function open() {
      sidebar?.classList.add('is-open');
      mask?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      sidebar?.classList.remove('is-open');
      mask?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLElement>('[data-sidebar-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (sidebar?.classList.contains('is-open')) close();
        else open();
      });
    });
    mask.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
    // Close when clicking a sidebar link on mobile
    sidebar.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        if (window.matchMedia('(max-width: 1023px)').matches) close();
      }),
    );

    // Desktop collapse
    if (collapseBtn && window.matchMedia('(min-width: 1024px)').matches) {
      collapseBtn.addEventListener('click', () => {
        setCollapsed(true);
      });
    }

    // Desktop expand
    if (expandBtn && window.matchMedia('(min-width: 1024px)').matches) {
      expandBtn.addEventListener('click', () => {
        setCollapsed(false);
      });
    }
  }

  function setCollapsed(isCollapsed: boolean) {
    const sidebar = document.getElementById('sidebar');
    if (!sidebar) return;

    localStorage.setItem(STORAGE_KEY, isCollapsed ? 'true' : 'false');

    if (isCollapsed) {
      sidebar.classList.add('is-collapsed');
      document.documentElement.setAttribute('data-sidebar-collapsed', '');
    } else {
      sidebar.classList.remove('is-collapsed');
      document.documentElement.removeAttribute('data-sidebar-collapsed');
    }
  }

  function initCollapseState() {
    const sidebar = document.getElementById('sidebar');
    if (!sidebar || window.matchMedia('(max-width: 1023px)').matches) return;

    const stored = localStorage.getItem(STORAGE_KEY);
    const isCollapsed = stored === 'true';
    setCollapsed(isCollapsed);
  }

  // Restore state on page load
  initCollapseState();
  document.addEventListener('astro:page-load', () => {
    setupSidebar();
    initCollapseState();
  });
</script>

<style>
  /* Collapse button next to logo when expanded */
  .sidebar-expanded-collapse-btn {
    color: var(--color-sidebar-text);
    background: transparent;
  }
  .sidebar-expanded-collapse-btn:hover {
    color: var(--color-primary);
    background: color-mix(in oklab, var(--color-primary) 8%, transparent);
  }

  /* Expand button — hidden when expanded, shown as nav item when collapsed */
  .sidebar-expand-btn {
    display: none;
  }
  :global(.chirpy-sidebar.is-collapsed) .sidebar-expand-btn {
    display: flex;
  }

  /* Hide entire expanded-only sections when collapsed */
  :global(.chirpy-sidebar.is-collapsed) :global(.sidebar-expanded-only) {
    display: none !important;
  }

  /* Hide collapse/expand buttons on mobile — sidebar toggle is handled by hamburger menu */
  @media (max-width: 1023px) {
    .sidebar-expanded-collapse-btn,
    .sidebar-expand-btn {
      display: none !important;
    }
  }
</style>
