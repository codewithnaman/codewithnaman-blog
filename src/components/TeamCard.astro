---
interface Props {
  name: string;
  role: string;
  bio: string;
  avatarUrl?: string;
  socials?: { label: string; href: string; icon: string }[];
}

const { name, role, bio, avatarUrl, socials = [] } = Astro.props;
---

<div class="card bg-base-100 border-base-200 border shadow-md">
  <div class="card-body p-5">
    <div class="flex items-center gap-4">
      <div class="avatar placeholder">
        <div class="bg-neutral text-neutral-content w-16 rounded-full">
          {
            avatarUrl ? (
              <img src={avatarUrl} alt={name} class="h-full w-full rounded-full object-cover" />
            ) : (
              <span class="text-2xl font-bold">{name.charAt(0)}</span>
            )
          }
        </div>
      </div>
      <div>
        <h3 class="text-lg font-bold">{name}</h3>
        <p class="text-base-content/60 text-sm">{role}</p>
      </div>
    </div>
    <p class="text-base-content/80 mt-3 text-sm">{bio}</p>
    {
      socials.length > 0 && (
        <div class="mt-4 flex gap-3">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost btn-xs gap-1"
              aria-label={`${social.label} of ${name}`}
            >
              <span class="iconify" data-icon={social.icon} data-width="16" />
              {social.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</div>
