---
import { Icon } from 'astro-icon/components';

interface Props {
  name: string;
  role: string;
  bio: string;
  avatarUrl?: string;
  socials?: { label: string; href: string; icon: string }[];
}

const { name, role, bio, avatarUrl, socials = [] } = Astro.props;
---

<div class="card bg-base-100 border-base-200 border shadow-md">
  <div class="card-body p-5">
    <div class="flex items-center gap-4">
      <div class="avatar placeholder shrink-0">
        <div class="bg-neutral text-neutral-content h-16 w-16 rounded-full">
          {
            avatarUrl ? (
              <img src={avatarUrl} alt={name} class="mt-0.5 rounded-full" />
            ) : (
              <span class="text-2xl font-bold">{name.charAt(0)}</span>
            )
          }
        </div>
      </div>
      <div>
        <h3 class="text-lg leading-none font-bold">{name}</h3>
        <p class="text-base-content/60 -mt-3 text-sm">{role}</p>
      </div>
    </div>
    <p class="text-base-content/80 mt-1 text-sm">{bio}</p>
    {
      socials.length > 0 && (
        <div class="mt-4 flex gap-4">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-base-content/60 hover:text-base-content transition-colors"
              aria-label={`${social.label} of ${name}`}
            >
              <Icon name={social.icon} width={20} height={20} />
            </a>
          ))}
        </div>
      )
    }
  </div>
</div>
