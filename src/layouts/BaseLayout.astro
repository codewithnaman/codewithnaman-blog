---
import '../styles/global.css';

import { Font } from 'astro:assets';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import Panel from '../components/Panel.astro';
import SEO from '../components/SEO.astro';
import BackToTop from '../components/islands/BackToTop.astro';
import { ClientRouter } from 'astro:transitions';
import { SITE } from '../config';
import { useTranslations, withBase } from '../i18n/utils';
import { buildSeo, type SeoMeta } from '../utils/seo';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  /** Hide the right panel (e.g. on post pages where TOC takes its place). */
  hidePanel?: boolean;
  /** Constrain main content width (used by Pages like About/404). */
  narrow?: boolean;
  /** Breadcrumb segments shown in the topbar. */
  crumbs?: Array<{ label: string; href?: string }>;
  /** Pre-built SEO meta override. */
  seo?: SeoMeta;
}

const {
  title,
  description,
  ogImage,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags,
  hidePanel = false,
  narrow = false,
  crumbs = [],
  seo,
} = Astro.props;

const t = useTranslations();
const lang = 'en';

const pathWithoutLocale = Astro.url.pathname;
const meta: SeoMeta =
  seo ??
  buildSeo({
    title,
    description,
    pathWithoutLocale,
    fullPath: Astro.url.pathname,
    ogImage,
    type,
    publishedTime,
    modifiedTime,
    tags,
  });
---

<!doctype html>
<html lang={lang} data-theme="chirpy-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1b1b1e" />
    <link rel="icon" type="image/x-icon" href={withBase('/favicon.ico')} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={withBase('/rss.xml')}
    />
    <SEO meta={meta} />
    {/* JSON-LD: WebSite + Organization */}
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'WebSite',
            '@id': `${SITE.url}/#website`,
            url: SITE.url,
            name: SITE.title,
            description: SITE.description,
            publisher: { '@id': `${SITE.url}/#organization` },
          },
          {
            '@type': 'Organization',
            '@id': `${SITE.url}/#organization`,
            name: SITE.author.name,
            url: SITE.author.url ?? SITE.url,
            ...(SITE.author.avatar && {
              logo: {
                '@type': 'ImageObject',
                url: new URL(SITE.author.avatar as string, SITE.url).toString(),
              },
            }),
          },
        ],
      })}
    />
    {/* Custom fonts configured via Astro Fonts API */}
    <Font cssVariable="--font-source-sans-3" />
    <Font cssVariable="--font-lato" />
    <Font cssVariable="--font-jetbrains-mono" preload />
    <ClientRouter />
    {/* Apply persisted theme as early as possible to avoid FOUC. */}
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var stored = localStorage.getItem('theme');
            var valid = stored === 'chirpy-dark' || stored === 'chirpy-light';
            var theme = valid ? stored : 'chirpy-dark';
            if (!valid && stored) localStorage.setItem('theme', theme);
            document.documentElement.setAttribute('data-theme', theme);
          } catch {
            /* ignore */
          }
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
  </head>

  <body>
    <a
      href="#main"
      class="focus:bg-primary focus:text-primary-content sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:px-3 focus:py-2"
    >
      {t('site.skipToContent')}
    </a>

    <Sidebar />

    <div class="chirpy-main-wrapper">
      <div class="chirpy-shell">
        <Topbar crumbs={crumbs} />

        <div class="flex flex-1 gap-10">
          <div class="flex min-w-0 flex-1 flex-col">
            <main
              id="main"
              aria-label="Main Content"
              class:list={['min-w-0 flex-1 py-6 lg:pr-2', narrow ? 'mx-auto w-full max-w-3xl' : '']}
            >
              <slot />
            </main>

            <Footer />
          </div>

          {
            !hidePanel && (
              <aside class="chirpy-panel-rail" aria-label="Sidebar widgets">
                <Panel />
                <slot name="aside-bottom" />
              </aside>
            )
          }
        </div>
      </div>
    </div>

    <BackToTop />
  </body>
</html>
