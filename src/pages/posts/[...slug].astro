---
import { render } from 'astro:content';
import PostLayout from '~/layouts/PostLayout.astro';
import { getPosts, getRelatedPosts, postSlug, sortPostsByDate, type Post } from '~/utils/posts';

interface Props {
  post: Post;
  prev?: Post;
  next?: Post;
  relatedPosts: Post[];
}

export async function getStaticPaths() {
  const allPosts = await getPosts();
  const chronological = sortPostsByDate(allPosts);

  return allPosts.map((post) => {
    const i = chronological.findIndex((p) => p.id === post.id);
    const related = getRelatedPosts(post, allPosts, 3);
    return {
      params: { slug: postSlug(post) },
      props: {
        post,
        prev: chronological[i + 1],
        next: chronological[i - 1],
        relatedPosts: related,
      },
    };
  });
}

const { post, prev, next, relatedPosts } = Astro.props as Props;
const { Content, headings } = await render(post);
const body = post.body ?? '';
---

<PostLayout
  post={post}
  headings={headings}
  body={body}
  prev={prev}
  next={next}
  relatedPosts={relatedPosts}
>
  <Content />
</PostLayout>
