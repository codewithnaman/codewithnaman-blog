---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostList from '~/components/PostList.astro';
import { useTranslations } from '~/i18n/utils';
import { getPosts, getTagsWithCount, slugify, postPath } from '~/utils/posts';
import { SITE } from '~/config';

export async function getStaticPaths() {
  const tags = await getTagsWithCount();
  return tags.map((tag) => ({
    params: { tag: slugify(tag.name) },
    props: { tagName: tag.name },
  }));
}

const { tagName } = Astro.props;
const { tag } = Astro.params;
const t = useTranslations();
const posts = (await getPosts()).filter((p) => p.data.tags.some((tg) => slugify(tg) === tag));

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `#${tagName} — ${SITE.title}`,
  itemListElement: posts.map((post, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(postPath(post), SITE.url).toString(),
    name: post.data.title,
  })),
};
---

<BaseLayout
  title={`#${tagName} — ${SITE.title}`}
  description={`Browse all posts tagged #${tagName} on ${SITE.title}.`}
  crumbs={[{ label: t('tags.title'), href: '/tags/' }, { label: `#${tagName}` }]}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />
  <header class="mb-6">
    <p class="text-base-content/70 text-sm tracking-wide uppercase">{t('list.tagPosts')}</p>
    <h1 class="text-3xl font-bold tracking-tight">#{tagName}</h1>
    <p class="text-base-content/70 mt-1 text-sm">
      {posts.length}
      {posts.length === 1 ? t('list.totalPostsOne') : t('list.totalPosts')}
    </p>
  </header>
  <PostList posts={posts} />
</BaseLayout>
