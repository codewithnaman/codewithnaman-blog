---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { useTranslations } from '~/i18n/utils';
import { getTagsWithCount, tagPath } from '~/utils/posts';
import { SITE } from '~/config';
import { Icon } from 'astro-icon/components';

const t = useTranslations();
const tags = await getTagsWithCount();
---

<BaseLayout
  title={`All Tags — ${SITE.title}`}
  description={`Browse all topics and tags covered on ${SITE.title}.`}
  crumbs={[{ label: t('tags.title') }]}
>
  <header class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight">{t('tags.title')}</h1>
  </header>
  {
    tags.length === 0 ? (
      <p class="text-base-content/70">{t('tags.empty')}</p>
    ) : (
      <ul class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <li>
            <a href={tagPath(tag.name)} class="badge badge-lg gap-1">
              <Icon name="lucide:tag" width={12} height={12} />
              {tag.name}
              <span class="text-base-content/70">{tag.count}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
